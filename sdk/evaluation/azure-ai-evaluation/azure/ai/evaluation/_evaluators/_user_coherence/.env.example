# Azure AI Foundry project endpoint (used by fetch_agent_conversations.py)
PROJECT_ENDPOINT="https://<account>-resource.services.ai.azure.com/api/projects/<project>""

# Comma-separated list of agent names to fetch conversations for
AGENTS="legal-contract-review-sim,airline-customer-service-sim"

# Maximum number of conversations to fetch per agent
MAX_CONVERSATIONS=30

# Azure OpenAI configuration for the evaluator (used by notebook)
AZURE_OPENAI_ENDPOINT="https://<account>.cognitiveservices.azure.com/""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
AZURE_OPENAI_DEPLOYMENT="gpt-4.1"
